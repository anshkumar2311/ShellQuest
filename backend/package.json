{
  "name": "shellquest-backend",
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "seed": "npx tsx src/db/seed.ts",
    "migrate": "node -r ts-node/register src/db/migrate.ts"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "pg": "^8.22.0",
    "socket.io": "^4.7.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}